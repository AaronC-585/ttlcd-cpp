      "x": 130,
      "y": 70,
      "gpu_type": "nvidia",
      "display_mode": "percent",
      "font_size": 9,
      "font_color": [200, 200, 255]
    },
    
    {
      "_comment": "=== NETWORK SECTION ===",
      "type": "text",
      "enable": true,
      "x": 5,
      "y": 76,
      "text": "Net",
      "font_size": 9,
      "font_color": [150, 200, 255]
    },
    {
      "type": "network",
      "enable": true,
      "x": 35,
      "y": 76,
      "font_size": 8,
      "font_color": [150, 220, 255]
    },
    {
      "type": "network_interface",
      "enable": true,
      "x": 140,
      "y": 76,
      "interface": "eth0",
      "display_mode": "ip",
      "font_size": 8,
      "font_color": [180, 180, 200]
    },
    
    {
      "_comment": "=== DISK I/O SECTION ===",
      "type": "text",
      "enable": true,
      "x": 250,
      "y": 76,
      "text": "I/O",
      "font_size": 9,
      "font_color": [255, 200, 150]
    },
    {
      "type": "disk_io",
      "enable": true,
      "x": 275,
      "y": 76,
      "device": "sda",
      "font_size": 7,
      "font_color": [255, 220, 180]
    },
    
    {
