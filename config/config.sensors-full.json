{
  "idVendor": 9256,
  "idProduct": 13581,
  "use": "NODE",
  
  "background": "/path/to/background.jpg",
  "orientation": "TOP",
  "font_file": "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf",
  "font_size": 10,
  
  "_comment": "Comprehensive Sensor Configuration - All Available Widgets",
  
  "usb_timeout_ms": 30000,
  "packet_delay_ms": 1000,
  "update_interval_sec": 2,
  
  "enable_ping": true,
  "ping_interval_sec": 30,
  
  "widgets": [
    {
      "_comment": "=== HEADER SECTION ===",
      "type": "text",
      "enable": true,
      "x": 10,
      "y": 12,
      "text": "SYSTEM MONITOR",
      "font_size": 12,
      "font_color": [255, 255, 255]
    },
    {
      "type": "time",
      "enable": true,
      "x": 380,
      "y": 12,
      "font_size": 10,
      "font_color": [200, 200, 200]
    },
    {
      "type": "uptime",
      "enable": true,
      "x": 200,
      "y": 12,
      "font_size": 9,
      "font_color": [180, 180, 180]
    },
    {
      "type": "line",
      "enable": true,
      "x": 0,
      "y": 18,
      "orientation": "horizontal",
      "length": 480,
      "thickness": 1,
      "line_color": [100, 100, 100]
    },
    
    {
      "_comment": "=== CPU SECTION ===",
      "type": "text",
      "enable": true,
      "x": 5,
      "y": 30,
      "text": "CPU",
      "font_size": 9,
      "font_color": [200, 150, 150]
    },
    {
      "type": "cpu_bar",
      "enable": true,
      "x": 35,
      "y": 24,
      "width": 100,
      "height": 14,
      "direction": "right"
    },
    {
      "type": "cpu_temp",
      "enable": true,
      "x": 140,
      "y": 30,
      "font_size": 9,
      "font_color": [255, 200, 150]
    },
    {
      "type": "cpu_freq",
      "enable": true,
      "x": 190,
      "y": 30,
      "font_size": 9,
      "font_color": [150, 200, 255]
    },
    
    {
      "_comment": "=== CPU CORES (Multi-core display) ===",
      "type": "text",
      "enable": true,
      "x": 270,
      "y": 30,
      "text": "Cores:",
      "font_size": 8,
      "font_color": [180, 180, 180]
    },
    {
      "type": "cpu_core",
      "enable": true,
      "x": 305,
      "y": 30,
      "core_id": -1,
      "font_size": 8,
      "font_color": [200, 200, 200]
    },
    
    {
