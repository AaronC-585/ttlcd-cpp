    {
      "type": "text",
      "enable": true,
      "x": 5,
      "y": 50,
      "text": "RAM",
      "font_size": 9,
      "font_color": [150, 200, 150]
    },
    {
      "type": "ram_bar",
      "enable": true,
      "x": 35,
      "y": 44,
      "width": 100,
      "height": 14
    },
    {
      "type": "memory_details",
      "enable": true,
      "x": 140,
      "y": 50,
