    {
      "_comment": "=== FOOTER ===",
      "type": "line",
      "enable": true,
      "x": 0,
      "y": 120,
      "orientation": "horizontal",
      "length": 480,
      "thickness": 2,
      "line_color": [100, 100, 100]
